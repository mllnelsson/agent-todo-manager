  "bugs": [
    {
      "id": "00000000-0000-0000-0002-000000000400",
      "seq": 1,
      "prefix": "b",
      "title": "Memory leak in batch parser under high throughput",
      "description": "When processing >10k events/s the process RSS grows without bound. Suspected buffer not being released after parse. Observed on staging with a 2-hour soak test.",
      "status": "in_progress",
      "created_at": "2026-03-29T11:00:00Z",
      "updated_at": "2026-03-30T08:00:00Z",
      "steps": [
        {
          "id": "00000000-0000-0000-0002-000006000001",
          "seq": 1,
          "title": "Profile memory with tracemalloc",
          "description": "Run tracemalloc snapshots at 60 s intervals during the soak test.",
          "status": "in_progress",
          "created_at": "2026-03-29T11:05:00Z",
          "updated_at": "2026-03-30T08:00:00Z"
        },
        {
          "id": "00000000-0000-0000-0002-000006000002",
          "seq": 2,
          "title": "Fix buffer lifecycle in syslog listener",
          "description": "Release byte buffer after LogEvent is handed off to queue.",
          "status": "todo",
          "created_at": "2026-03-29T11:05:00Z",
          "updated_at": "2026-03-29T11:05:00Z"
        }
      ]
    }
