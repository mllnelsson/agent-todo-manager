              "updated_at": "2026-03-16T12:00:00Z"
            },
            {
              "id": "00000000-0000-0000-0002-000001000002",
              "seq": 2,
              "title": "Write schema.md with field table",
              "description": "Document each field: name, type, nullable, source.",
              "status": "completed",
              "created_at": "2026-03-16T12:00:00Z",
              "updated_at": "2026-03-17T16:00:00Z"
            }
          ]
        },
        {
          "id": "00000000-0000-0000-0002-000000000101",
          "seq": 2,
          "prefix": null,
          "title": "Log parser",
          "description": "Parse raw bytes from HTTP and syslog into canonical LogEvent objects.",
          "status": "completed",
          "created_at": "2026-03-18T09:00:00Z",
          "updated_at": "2026-03-22T17:00:00Z",
          "steps": [
            {
