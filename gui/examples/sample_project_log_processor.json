              "status": "completed",
              "created_at": "2026-03-20T14:00:00Z",
              "updated_at": "2026-03-21T17:00:00Z"
            },
            {
              "id": "00000000-0000-0000-0002-000002000003",
              "seq": 3,
              "title": "Unit tests for both parsers",
              "description": "Cover malformed input, large payloads, and encoding edge cases.",
              "status": "completed",
              "created_at": "2026-03-21T17:00:00Z",
              "updated_at": "2026-03-22T17:00:00Z"
            }
          ]
        }
