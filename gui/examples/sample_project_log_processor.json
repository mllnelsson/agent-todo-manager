{
  "id": "00000000-0000-0000-0002-000000000001",
  "title": "Log Processor",
  "description": "Streaming log ingestion and enrichment pipeline. Parses structured logs from multiple sources, applies enrichment rules (geo-lookup, threat intel), and forwards to downstream storage.",
  "status": "in_progress",
  "created_at": "2026-03-15T08:00:00Z",
  "updated_at": "2026-03-30T09:00:00Z",
  "stories": [
    {
      "id": "00000000-0000-0000-0002-000000000010",
      "seq": 1,
      "title": "Ingestion layer",
      "description": "Accept log streams over HTTP and syslog. Validate, normalise, and hand off to the processing queue.",
      "status": "completed",
      "created_at": "2026-03-15T08:05:00Z",
      "updated_at": "2026-03-22T17:00:00Z",
      "tasks": [
